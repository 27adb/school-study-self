<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.room.reservation.mapper.CarpoolGroupMapper">
    <resultMap id="Cg" type="CarpoolGroup">
        <id property="id" column="id"/>
        <result property="roomId" column="room_id"/>
        <result property="leaderUserId" column="leader_user_id"/>
        <result property="seatCount" column="seat_count"/>
        <result property="shareCode" column="share_code"/>
        <result property="status" column="status"/>
        <result property="expireTime" column="expire_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <insert id="insertCarpoolGroup" useGeneratedKeys="true" keyProperty="id">
        insert into room_carpool_group (room_id, leader_user_id, seat_count, share_code, status, expire_time)
        values (#{roomId}, #{leaderUserId}, #{seatCount}, #{shareCode}, #{status}, #{expireTime})
    </insert>
    <select id="selectByShareCode" resultMap="Cg">
        select * from room_carpool_group where share_code = #{shareCode} limit 1
    </select>
    <update id="updateStatus">
        update room_carpool_group set status = #{status} where id = #{id}
    </update>
</mapper>
