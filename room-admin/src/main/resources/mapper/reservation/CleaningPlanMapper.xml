<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.room.reservation.mapper.CleaningPlanMapper">
    <resultMap id="ClnResult" type="CleaningPlan">
        <id property="id" column="id"/>
        <result property="roomId" column="room_id"/>
        <result property="planDate" column="plan_date"/>
        <result property="timeSlot" column="time_slot"/>
        <result property="cleaner" column="cleaner"/>
        <result property="status" column="status"/>
        <result property="reason" column="reason"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <select id="selectCleaningList" resultMap="ClnResult">
        select id, room_id, plan_date, time_slot, cleaner, status, reason, create_time
        from room_cleaning_plan
        <where>
            <if test="roomId != null">and room_id = #{roomId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by plan_date desc, id desc
    </select>
    <insert id="insertCleaning" useGeneratedKeys="true" keyProperty="id">
        insert into room_cleaning_plan (room_id, plan_date, time_slot, cleaner, status, reason)
        values (#{roomId}, #{planDate}, #{timeSlot}, #{cleaner}, #{status}, #{reason})
    </insert>
    <update id="updateCleaning">
        update room_cleaning_plan
        <set>
            <if test="cleaner != null">cleaner = #{cleaner},</if>
            <if test="status != null">status = #{status},</if>
            <if test="reason != null">reason = #{reason},</if>
        </set>
        where id = #{id}
    </update>
    <delete id="deleteCleaningById">delete from room_cleaning_plan where id = #{id}</delete>
</mapper>
