<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.room.reservation.mapper.FeedbackRecordMapper">

    <resultMap type="FeedbackRecord" id="FeedbackRecordResult">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="feedbackType" column="feedback_type"/>
        <result property="content" column="content"/>
        <result property="quietScore" column="quiet_score"/>
        <result property="lightingScore" column="lighting_score"/>
        <result property="appealEvidence" column="appeal_evidence"/>
        <result property="status" column="status"/>
        <result property="handleRemark" column="handle_remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectFeedbackRecordVo">
        select id, user_id, feedback_type, content, quiet_score, lighting_score, appeal_evidence, status, handle_remark, create_by, create_time, update_by, update_time, remark
        from room_feedback_record
    </sql>

    <select id="selectFeedbackRecordById" parameterType="Long" resultMap="FeedbackRecordResult">
        <include refid="selectFeedbackRecordVo"/>
        where id = #{id}
    </select>

    <select id="selectFeedbackRecordList" parameterType="FeedbackRecord" resultMap="FeedbackRecordResult">
        <include refid="selectFeedbackRecordVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="feedbackType != null and feedbackType != ''">and feedback_type = #{feedbackType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by id desc
    </select>

    <select id="selectRecentByUserId" resultMap="FeedbackRecordResult">
        <include refid="selectFeedbackRecordVo"/>
        where user_id = #{userId}
        order by id desc
        limit #{limit}
    </select>

    <insert id="insertFeedbackRecord" parameterType="FeedbackRecord" useGeneratedKeys="true" keyProperty="id">
        insert into room_feedback_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="feedbackType != null and feedbackType != ''">feedback_type,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="quietScore != null">quiet_score,</if>
            <if test="lightingScore != null">lighting_score,</if>
            <if test="appealEvidence != null and appealEvidence != ''">appeal_evidence,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="handleRemark != null and handleRemark != ''">handle_remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="feedbackType != null and feedbackType != ''">#{feedbackType},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="quietScore != null">#{quietScore},</if>
            <if test="lightingScore != null">#{lightingScore},</if>
            <if test="appealEvidence != null and appealEvidence != ''">#{appealEvidence},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="handleRemark != null and handleRemark != ''">#{handleRemark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            now(),
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateFeedbackRecord" parameterType="FeedbackRecord">
        update room_feedback_record
        <trim prefix="set" suffixOverrides=",">
            <if test="feedbackType != null and feedbackType != ''">feedback_type = #{feedbackType},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="quietScore != null">quiet_score = #{quietScore},</if>
            <if test="lightingScore != null">lighting_score = #{lightingScore},</if>
            <if test="appealEvidence != null">appeal_evidence = #{appealEvidence},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="handleRemark != null">handle_remark = #{handleRemark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = now(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

</mapper>

