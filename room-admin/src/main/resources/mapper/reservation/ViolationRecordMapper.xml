<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.room.reservation.mapper.ViolationRecordMapper">
    <resultMap id="VioResult" type="ViolationRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="reservationId" column="reservation_id"/>
        <result property="violationType" column="violation_type"/>
        <result property="description" column="description"/>
        <result property="evidenceUrls" column="evidence_urls"/>
        <result property="signLog" column="sign_log"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <sql id="c">id, user_id, reservation_id, violation_type, description, evidence_urls, sign_log, create_by, create_time</sql>
    <select id="selectViolationList" resultMap="VioResult">
        select <include refid="c"/> from room_violation
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="violationType != null and violationType != ''">and violation_type = #{violationType}</if>
        </where>
        order by id desc
    </select>
    <select id="selectViolationById" resultMap="VioResult">
        select <include refid="c"/> from room_violation where id = #{id}
    </select>
    <insert id="insertViolation" useGeneratedKeys="true" keyProperty="id">
        insert into room_violation (user_id, reservation_id, violation_type, description, evidence_urls, sign_log, create_by)
        values (#{userId}, #{reservationId}, #{violationType}, #{description}, #{evidenceUrls}, #{signLog}, #{createBy})
    </insert>
    <delete id="deleteViolationById">delete from room_violation where id = #{id}</delete>

    <select id="countSince" resultType="int">
        select count(*) from room_violation
        where user_id = #{userId}
        <if test="since != null">and create_time &gt;= #{since}</if>
    </select>
</mapper>
